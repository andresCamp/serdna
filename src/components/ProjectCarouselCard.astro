---
import { Image } from "astro:assets";

interface Props {
  title: string;
  description: string;
  href: string;
  logo?: ImageMetadata;
  class?: string;
}

const { title, description, href, logo, class: className = '' } = Astro.props;
---

<a
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  class:list={[
    'group/card flex-shrink-0 snap-start w-[280px] md:w-[340px] aspect-[4/5] rounded-2xl overflow-hidden relative bg-neutral-100',
    className,
  ]}
>
  <!-- Default layer: media (slot) -->
  <div class="absolute inset-0 transition-opacity duration-500 group-hover/card:opacity-0">
    <slot />
  </div>

  <!-- Hover layer: faded watermark logo + description text -->
  <div class="absolute inset-0 bg-neutral-950 opacity-0 transition-opacity duration-500 group-hover/card:opacity-100">
    {logo && (
      <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
        <Image
          src={logo}
          alt=""
          aria-hidden="true"
          class="w-24 h-24 md:w-28 md:h-28 object-contain opacity-[0.12]"
        />
      </div>
    )}
    <div class="relative z-10 h-full flex flex-col items-center justify-center px-6 text-center">
      <p class="text-[11px] uppercase tracking-[0.2em] text-neutral-500 font-medium mb-3">{title}</p>
      <p class="text-sm text-neutral-200 leading-relaxed max-w-[260px]">{description}</p>
    </div>
  </div>
</a>
