---
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<canvas data-digital-rain class:list={['w-full h-full', className]}></canvas>

<script>
  const rain = document.querySelector('[data-digital-rain]') as HTMLCanvasElement;
  if (rain) {
    const ctx = rain.getContext('2d')!;
    const dpr = Math.min(window.devicePixelRatio, 2);
    let w = 0, h = 0;

    const chars = 'アイウエオカキクケコサシスセソタチツテトナニヌネノハヒフヘホマミムメモヤユヨラリルレロワヲン0123456789ABCDEF<>{}[]=/\\';

    interface Column {
      x: number;
      y: number;
      speed: number;
      length: number;
      chars: string[];
      depth: number;
      fontSize: number;
    }

    let columns: Column[] = [];

    function initColumns() {
      w = rain.clientWidth;
      h = rain.clientHeight;
      rain.width = w * dpr;
      rain.height = h * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);

      columns = [];
      const centerX = w / 2;
      const maxDist = w / 2;
      const baseCols = Math.floor(w / 12);

      for (let i = 0; i < baseCols; i++) {
        const x = (i / baseCols) * w;
        const distFromCenter = Math.abs(x - centerX) / maxDist;
        const depth = Math.pow(distFromCenter, 0.7);
        columns.push(createColumn(x, depth, true));
      }
    }

    function createColumn(x: number, depth: number, initial: boolean): Column {
      const fontSize = 8 + depth * 10;
      const speed = 0.3 + depth * 2.0;
      const length = 5 + Math.floor(depth * 15) + Math.floor(Math.random() * 8);

      const colChars: string[] = [];
      for (let j = 0; j < length; j++) {
        colChars.push(chars[Math.floor(Math.random() * chars.length)]);
      }

      return {
        x,
        y: initial ? Math.random() * h * -1.5 : -length * fontSize,
        speed,
        length,
        chars: colChars,
        depth,
        fontSize,
      };
    }

    initColumns();
    window.addEventListener('resize', initColumns);

    let frame = 0;
    function draw() {
      frame++;
      ctx.fillStyle = '#ffffff';
      ctx.fillRect(0, 0, w, h);

      ctx.textAlign = 'center';

      for (const col of columns) {
        if (frame % 4 === 0 && col.length > 1) {
          const idx = Math.floor(Math.random() * col.chars.length);
          col.chars[idx] = chars[Math.floor(Math.random() * chars.length)];
        }

        ctx.font = `${col.fontSize}px monospace`;

        for (let j = 0; j < col.length; j++) {
          const charY = col.y + j * col.fontSize;
          if (charY < -col.fontSize || charY > h + col.fontSize) continue;

          const distFromHead = col.length - 1 - j;

          let baseAlpha: number;
          if (distFromHead === 0) {
            baseAlpha = 0.12 + col.depth * 0.20;
          } else if (distFromHead < 3) {
            baseAlpha = 0.06 + col.depth * 0.12;
          } else {
            const fadeRatio = distFromHead / col.length;
            baseAlpha = Math.max(0.02, (0.05 + col.depth * 0.08) * (1 - fadeRatio));
          }

          ctx.fillStyle = `rgba(0, 0, 0, ${baseAlpha})`;
          ctx.fillText(col.chars[j], col.x, charY);
        }

        col.y += col.speed;

        if (col.y - col.length * col.fontSize > h) {
          const reset = createColumn(col.x, col.depth, false);
          col.y = reset.y;
          col.speed = reset.speed;
          col.length = reset.length;
          col.chars = reset.chars;
        }
      }

      requestAnimationFrame(draw);
    }

    draw();
  }
</script>
