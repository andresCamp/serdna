---
import Layout from "../layouts/Layout.astro";
import "../styles/global.css";
import { Image } from "astro:assets";
import ParallaxPortrait from "../components/ParallaxPortrait.astro";
import FeaturedProject from "../components/FeaturedProject.astro";

import envoyImg from "../assets/work/envoy/preview.png";
import envoyLogo from "../assets/work/envoy/logo.svg";
import osisImg from "../assets/work/osis/preview.png";
import osisLogo from "../assets/work/osis/logo.svg";
import artDirectLogo from "../assets/work/art-direct/logo.svg";
import rptImg from "../assets/work/rpt/preview.png";
import rptLogo from "../assets/work/rpt/logo.svg";
import mystoryLogo from "../assets/work/mystory/logo.svg";
import mystoryImg from "../assets/work/mystory/preview.png";
import initialcommitLogo from "../assets/work/initialcommit/logo.svg";
import icHeroDhow from "../assets/work/initialcommit/hero-dhow.webp";
import icHeroDunes from "../assets/work/initialcommit/hero-dunes.jpeg";
import icHeroMangroves from "../assets/work/initialcommit/hero-mangroves.jpeg";
import onc9Logo from "../assets/work/onc9/logo.svg";

// Open-source repos: static snapshot in src/data/oss-repos.json.
// Refresh with: `gh api 'users/andresCamp/repos?type=owner&sort=updated&per_page=100' --jq '[.[] | select(.fork == false and .archived == false and .description != null and (.description | length) > 0) | select(.name as $n | ["TrueMeridianSolutions","ViaSana-Web","osis-app"] | index($n) | not) | {name, description, html_url, pushed_at}] | sort_by(.pushed_at) | reverse | .[0:20]' > src/data/oss-repos.json`
import ossRepos from "../data/oss-repos.json";
---

<Layout>
  <!-- ============================================ -->
  <!-- SECTION 1: HERO                              -->
  <!-- ============================================ -->
  <section id="hero" class="fixed inset-0 overflow-hidden z-0 bg-white">
    <div id="hero-inner" class="h-full origin-center" style="transform: scale(1);">
    <div class="relative h-full max-w-7xl mx-auto px-4">
      <!-- Portrait — absolute, bottom center, behind content -->
      <div class="absolute bottom-0 left-1/2 z-0 -mb-6" style="transform: translateX(calc(-50% + 28px))">
        <ParallaxPortrait
          src="/portrait.png"
          depthSrc="/depthmask.png"
          alt="Andrés Campos"
          pauseObserve="#hero-spacer"
        />
      </div>

      <!-- Content overlay -->
      <div class="relative z-[1] flex flex-col justify-end lg:flex-row lg:justify-between h-full px-2 lg:px-8">

        <!-- Left: Identity — sits just above the portrait on mobile,
             bottom-anchored beside the portrait on desktop. -->
        <div id="hero-text" class="lg:self-end [padding-bottom:calc(50dvh+0.75rem)] lg:pb-24 origin-center">
          <h1 class="text-3xl md:text-5xl font-bold tracking-tight leading-[1.1]">
            Andrés Campos
          </h1>

          <p class="mt-4 max-w-md text-base md:text-lg leading-relaxed text-neutral-600">
            Full stack product engineer. I ship AI products and features end to end, from spec to design to infrastructure.
          </p>

          <div class="mt-5 flex flex-wrap items-center gap-3">
            <a href="https://www.linkedin.com/in/andres-l-campos/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center min-h-11 px-5 border border-neutral-300 rounded-full text-sm font-medium text-neutral-600 hover:border-neutral-400 transition-colors">LinkedIn</a>
            <a
              href="https://github.com/andresCamp"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="GitHub @andresCamp"
              class="inline-flex items-center min-h-11 gap-1.5 px-2 text-neutral-600 hover:text-neutral-900 transition-colors"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-github h-5 w-5" aria-hidden="true">
                <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/>
                <path d="M9 18c-4.51 2-5-2-7-2"/>
              </svg>
              <span class="text-sm font-medium">andresCamp</span>
            </a>
            <a
              href="/resume"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center min-h-11 px-2 text-sm font-medium text-neutral-600 hover:text-neutral-900 transition-colors"
            >
              Resume ↓
            </a>
          </div>

          <div class="mt-5 w-full lg:inline-block lg:w-auto">
            <div class="citizen-row grid grid-cols-4 gap-3 py-2 lg:flex lg:flex-wrap lg:items-center lg:gap-y-3 lg:gap-x-0">
            {[
              { label: "US Citizen", img: "/us.png", color: "#002868" },
              { label: "Mexican Citizen", img: "/mx.png", color: "#006341" },
              { label: "German Citizen", img: "/de.png", color: "#000000" },
              { label: "UAE Golden Visa", img: "/ae.png", color: "#C8102E" },
            ].map((item) => (
              <div class="citizen-item flex items-center justify-center cursor-none transition-all duration-300 lg:px-3" data-label={item.label} data-color={item.color}>
                <img src={item.img} alt={item.label} class="w-full h-auto aspect-square object-contain pointer-events-none lg:w-[48px] lg:h-[48px] lg:aspect-auto" />
              </div>
            ))}
            </div>
            <p class="text-[10px] font-medium text-neutral-400 uppercase tracking-widest mt-3 text-center">Available Globally</p>
          </div>
        </div>

      </div>
    </div>
    </div>
  </section>

  <!-- Spacer: pushes scrollable content below the fixed hero. The hero's
       ParallaxPortrait observes this element via IntersectionObserver and
       pauses its WebGL render loop once this spacer leaves the viewport
       (i.e., the visitor has scrolled past the hero). Re-enters → resumes. -->
  <div id="hero-spacer" class="h-dvh"></div>

  <!-- Scrollable content — rises over the fixed hero -->
  <div id="scroll-content" class="relative z-10 bg-white -mt-px rounded-t-[3.5rem] [filter:drop-shadow(0_-6px_12px_rgba(0,0,0,0.12))]">

  <!-- ============================================ -->
  <!-- SECTION 2: FEATURED WORK                     -->
  <!-- ============================================ -->
  <section id="work" class="px-4 md:px-8">
    <div class="max-w-7xl mx-auto">

      <FeaturedProject
        title="Osis"
        category="Developer Tool"
        description="Built to keep product context alive between coding agent sessions. The skill is the engine; desktop and web app are the interaction surfaces. Product clarity at the scale of managing multiple products to PMF."
        href="https://osis.dev"
        preview={osisImg}
        logo={osisLogo}
        techStack={["Markdown", "Astro", "Hono", "Drizzle", "Tauri", "Solid", "TanStack Start"]}
        imagePosition="left"
        diagramLabel="Protocol Hierarchy"
        diagram={`
  CANON (durable)
  ├── Vision ─────────── why
  └── Product Spec ───── what + when
         │
  PHASE (rotates)
  ├── Game Plan ──────── how
  └── System Specs
         ├── Product ─── behavior
         ├── Design ──── interface
         └── Implement ─ code

  Twin ◀──── codebase scan
  Signals ──▶ specs update`}
      />

      <FeaturedProject
        title="Art Direct"
        category="Creative Tool"
        description="Art direction tool, built in a day with AI tooling. Launched on Reddit; telemetry on the first 40 sessions showed nobody making it past the landing page to the studio. Iterated the funnel until activation went from zero to actual."
        href="https://artdirect.dev"
        video="https://cdn.serdna.dev/art-direct.mov"
        logo={artDirectLogo}
        techStack={["Astro", "Svelte"]}
        imagePosition="right"
        videoScale={1.02}
      />

      <FeaturedProject
        title="Rotating Power Technologies"
        category="Marketing Site"
        description="Marketing site for a turbine engineering consultancy entering the GCC market against global incumbents. Started with a 90-minute recorded conversation with the founder; the transcript became the spec. Bilingual EN/AR with regional content variants, privacy-first geo detection, Lighthouse 100."
        href="https://onc9.com/work/rpt"
        video="https://cdn.serdna.dev/rpt.mov"
        logo={rptLogo}
        techStack={["Astro", "React", "i18n"]}
        imagePosition="left"
        logoPosition="top-left"
        gradientStrength="subtle"
      />

      <FeaturedProject
        title="Envoy"
        category="Enterprise SaaS"
        description="Embassy inbox intelligence for diplomatic communications. Started with three hours of recorded conversations with an ambassador and the admin coordinator who'd built a 13-column spreadsheet workaround; transcripts became the spec. Multi-tenant SaaS with per-country data sovereignty enforced architecturally; 98% classification accuracy across 100+ edge case permutations."
        href="https://onc9.com/work/envoy"
        preview={envoyImg}
        logo={envoyLogo}
        techStack={["Next.js", "Inngest", "NestJS", "Neon", "Anthropic"]}
        imagePosition="right"
        diagramLabel="Per-Country Isolation"
        diagram={`
  ┌─────────────────────────────┐
  │        NestJS Gateway       │
  │    Hexagonal Architecture   │
  └──────────┬──────────────────┘
             │ country adapter
      ┌──────┼──────┐
      ▼      ▼      ▼
  ┌──────┐┌──────┐┌──────┐
  │ 🇨🇩 CD ││ 🇦🇪 AE ││ 🇺🇸 US │
  │ Neon  ││ Neon ││ Neon │
  └──┬───┘└──┬───┘└──┬───┘
     │       │       │
  ┌──▼───────▼───────▼───┐
  │    Inngest Pipelines  │
  │    Email Sync · AI    │
  └──────────┬────────────┘
             ▼
       Anthropic LLM`}
      />

      <FeaturedProject
        title="DeepMesh"
        category="Market Research"
        description="Research marketplace running entirely inside WhatsApp threads. Conversational agent handles requests, fulfillment, and delivery without a separate app surface. Won 'Most VC-Backable' at the Transpose c0mpiled hackathon in Abu Dhabi."
        href="https://deepmesh.io"
        video="https://cdn.serdna.dev/deepmesh.mp4"
        techStack={["Next.js", "Twilio", "PydanticAI", "Neon"]}
        imagePosition="left"
        diagramLabel="System Flow"
        diagram={`
  User (WhatsApp)
       │
       ▼
  ┌─────────┐    ┌────────────┐
  │ Twilio  │───▶│ PydanticAI │
  │ Webhook │    │ Agent      │
  └─────────┘    └─────┬──────┘
                       │
                 ┌─────▼──────┐
                 │    Neon     │
                 │  Research   │
                 │  Database   │
                 └─────┬──────┘
                       │
                 ┌─────▼──────┐
                 │  Response   │
                 │  → WhatsApp │
                 └────────────┘`}
      />

    </div>
  </section>

  <!-- ============================================ -->
  <!-- SECTION 2b: HORIZONTAL STRIP (more work)     -->
  <!-- Full-bleed image cards. Tech stack visible   -->
  <!-- by default; description swaps in on hover.   -->
  <!-- ============================================ -->
  <section class="py-8 px-4 md:px-8">
    <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-6">

      <!-- MyStory -->
      <a
        href="https://mystory.bio"
        target="_blank"
        rel="noopener noreferrer"
        class="strip-card group block relative aspect-[4/3] rounded-2xl overflow-hidden bg-neutral-100"
      >
        <Image src={mystoryImg} alt="MyStory" class="absolute inset-0 w-full h-full object-cover" />
        <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>
        <div class="absolute inset-0 flex items-center justify-center z-10 pointer-events-none">
          <Image src={mystoryLogo} alt="MyStory logo" class="w-20 h-20 md:w-24 md:h-24 object-contain drop-shadow-lg" />
        </div>
        <div class="strip-bottom absolute inset-x-0 bottom-0 z-10 p-4 flex flex-col gap-3">
          <p class="strip-desc text-sm text-white/95 leading-snug">AI life-story platform. Voice agents conduct documentary-style interviews; a biographer agent synthesizes across sessions. 192K LOC, five LLM providers.</p>
          <div class="strip-stack grid grid-cols-4 gap-2">
            <div class="inline-flex items-center justify-center h-7 bg-white/15 backdrop-blur-sm rounded-full"><img src="/tech/nextjs-wordmark.svg" alt="Next.js" class="tech-icon max-h-4 max-w-[60px] w-auto h-auto object-contain" /></div>
            <div class="inline-flex items-center justify-center h-7 bg-white/15 backdrop-blur-sm rounded-full"><img src="/tech/livekit-wordmark.svg" alt="LiveKit" class="tech-icon max-h-4 max-w-[72px] w-auto h-auto object-contain" /></div>
            <div class="inline-flex items-center justify-center h-7 bg-white/15 backdrop-blur-sm rounded-full"><img src="/tech/neo4j-lockup.svg" alt="Neo4j" class="tech-icon max-h-4 max-w-[72px] w-auto h-auto object-contain" /></div>
            <div class="inline-flex items-center justify-center h-7 bg-white/15 backdrop-blur-sm rounded-full"><img src="/tech/ably-lockup.svg" alt="Ably" class="tech-icon max-h-4 max-w-[72px] w-auto h-auto object-contain" /></div>
            <div class="inline-flex items-center justify-center h-7 bg-white/15 backdrop-blur-sm rounded-full"><img src="/tech/mux-wordmark.svg" alt="Mux" class="tech-icon max-h-4 max-w-[44px] w-auto h-auto object-contain" /></div>
            <div class="inline-flex items-center justify-center h-7 bg-white/15 backdrop-blur-sm rounded-full"><img src="/tech/stripe-wordmark.svg" alt="Stripe" class="tech-icon max-h-4 max-w-[72px] w-auto h-auto object-contain" /></div>
            <div class="inline-flex items-center justify-center h-7 bg-white/15 backdrop-blur-sm rounded-full"><img src="/tech/anthropic-wordmark.svg" alt="Anthropic" class="tech-icon max-h-4 max-w-[72px] w-auto h-auto object-contain" /></div>
            <div class="inline-flex items-center justify-center h-7 bg-white/15 backdrop-blur-sm rounded-full"><img src="/tech/openai-wordmark.svg" alt="OpenAI" class="tech-icon max-h-4 max-w-[52px] w-auto h-auto object-contain" /></div>
          </div>
        </div>
      </a>

      <!-- InitialCommit (image carousel) -->
      <a
        href="https://initialcommit.ae"
        target="_blank"
        rel="noopener noreferrer"
        class="strip-card group block relative aspect-[4/3] rounded-2xl overflow-hidden bg-neutral-900"
      >
        <div class="ic-cycle absolute inset-0">
          <Image src={icHeroDhow} alt="InitialCommit — dhow" class="absolute inset-0 w-full h-full object-cover opacity-100 transition-opacity duration-1000" />
          <Image src={icHeroDunes} alt="InitialCommit — dunes" class="absolute inset-0 w-full h-full object-cover opacity-0 transition-opacity duration-1000" />
          <Image src={icHeroMangroves} alt="InitialCommit — mangroves" class="absolute inset-0 w-full h-full object-cover opacity-0 transition-opacity duration-1000" />
        </div>
        <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>
        <div class="absolute inset-0 flex items-center justify-center z-10 pointer-events-none">
          <Image src={initialcommitLogo} alt="InitialCommit logo" class="w-64 h-64 md:w-80 md:h-80 object-contain drop-shadow-lg translate-x-[20%]" />
        </div>
        <div class="strip-bottom absolute inset-x-0 bottom-0 z-10 p-4 flex flex-col gap-3">
          <p class="strip-desc text-sm text-white/95 leading-snug">Abu Dhabi builder community. Events, brand identity, and a platform built from scratch for the AI engineer scene in the UAE.</p>
          <div class="strip-stack flex flex-wrap items-center gap-2">
            <div class="inline-flex items-center justify-center h-7 w-24 bg-white/15 backdrop-blur-sm rounded-full"><img src="/tech/nextjs-wordmark.svg" alt="Next.js" class="tech-icon max-h-4 max-w-[60px] w-auto h-auto object-contain" /></div>
            <div class="inline-flex items-center justify-center h-7 w-24 bg-white/15 backdrop-blur-sm rounded-full"><img src="/tech/prisma-lockup.svg" alt="Prisma" class="tech-icon max-h-4 max-w-[72px] w-auto h-auto object-contain" /></div>
          </div>
        </div>
      </a>

      <!-- ONC9 -->
      <a
        href="https://onc9.com"
        target="_blank"
        rel="noopener noreferrer"
        class="strip-card-light group block relative aspect-[4/3] rounded-2xl overflow-hidden bg-white"
      >
        <div class="absolute inset-0 flex items-center justify-center z-10 pointer-events-none">
          <Image src={onc9Logo} alt="ONC9 logo" class="w-32 h-32 md:w-40 md:h-40 object-contain" />
        </div>
        <div class="strip-bottom absolute inset-x-0 bottom-0 z-10 p-4 flex flex-col gap-3">
          <p class="strip-desc text-sm text-neutral-700 leading-snug">AI-native operations studio. Bespoke automation builds and a hosted operating layer for industrial firms.</p>
          <div class="strip-stack flex flex-wrap items-center gap-2">
            <div class="inline-flex items-center justify-center h-7 w-32 bg-neutral-900 rounded-full"><img src="/tech/tanstack-lockup.svg" alt="TanStack Start" class="tech-icon max-h-4 max-w-[100px] w-auto h-auto object-contain" /></div>
            <div class="inline-flex items-center justify-center h-7 w-24 bg-neutral-900 rounded-full"><img src="/tech/solid-lockup.svg" alt="Solid" class="tech-icon max-h-4 max-w-[72px] w-auto h-auto object-contain" /></div>
            <div class="inline-flex items-center justify-center h-7 w-24 bg-neutral-900 rounded-full"><img src="/tech/drizzle-lockup.svg" alt="Drizzle" class="tech-icon max-h-4 max-w-[72px] w-auto h-auto object-contain" /></div>
          </div>
        </div>
      </a>

    </div>

    <style>
      /* Force tech icons to monochrome white inside both the dark-bg
         strip cards (.strip-card) and the inverse-pill light card
         (.strip-card-light), since both render icons on a dark pill. */
      .strip-card .tech-icon,
      .strip-card-light .tech-icon {
        filter: brightness(0) invert(1);
      }

      /* Hover-capable pointers (desktop): preserve the original swap.
         Touch devices fall through to the default markup, where both
         description and tech stack flow inside .strip-bottom and stay
         visible together. */
      @media (hover: hover) {
        .strip-card .strip-desc,
        .strip-card-light .strip-desc {
          position: absolute;
          inset: auto 0 0 0;
          padding: 1.25rem;
          opacity: 0;
          transition: opacity 300ms;
          pointer-events: none;
        }
        .strip-card .strip-stack,
        .strip-card-light .strip-stack {
          transition: opacity 300ms;
        }
        .strip-card:hover .strip-desc,
        .strip-card-light:hover .strip-desc {
          opacity: 1;
        }
        .strip-card:hover .strip-stack,
        .strip-card-light:hover .strip-stack {
          opacity: 0;
        }
      }
    </style>
  </section>

  <!-- ============================================ -->
  <!-- SECTION 3: OPEN SOURCE                       -->
  <!-- ============================================ -->
  {ossRepos.length > 0 && (
    <section class="py-16 px-4 md:px-8">
      <div class="max-w-3xl mx-auto">
        <div class="flex items-center gap-4 mb-8">
          <h2 class="text-2xl font-semibold text-neutral-900">Open source</h2>
          <a
            href="https://github.com/andresCamp"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="GitHub @andresCamp"
            class="inline-flex items-center gap-2 text-neutral-500 hover:text-neutral-900 transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-github h-6 w-6" aria-hidden="true">
              <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/>
              <path d="M9 18c-4.51 2-5-2-7-2"/>
            </svg>
            <span class="text-base">andresCamp</span>
          </a>
        </div>
        <ul class="space-y-1 -mx-2">
          {ossRepos.map((repo) => (
            <li class="text-sm leading-relaxed">
              <a
                href={repo.html_url}
                target="_blank"
                rel="noopener noreferrer"
                class="group block min-h-11 py-3 px-2 rounded-md hover:bg-neutral-50 transition-colors"
              ><span class="text-neutral-900 font-medium group-hover:underline">{repo.name}</span><span class="text-neutral-500"> — {repo.description}</span></a>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  <!-- ============================================ -->
  <!-- SECTION 4: ABOUT + CTA (formerly Contact)    -->
  <!-- ============================================ -->
  <section id="contact" class="py-24 px-4 md:px-8">
    <div class="max-w-3xl mx-auto flex flex-col md:flex-row items-center gap-10 md:gap-14">

      <!-- Left column: mini parallax portrait, cropped to a circle -->
      <div class="shrink-0 w-48 h-48 md:w-56 md:h-56 rounded-full overflow-hidden bg-white relative">
        <div class="absolute bottom-0 left-1/2 -translate-x-1/2">
          <ParallaxPortrait
            src="/portrait.png"
            depthSrc="/depthmask.png"
            alt="Andrés Campos"
            style="width: 200px; height: 237px;"
          />
        </div>
      </div>

      <!-- Right column: friendly CTA + email -->
      <div class="flex flex-col items-start gap-4">
        <p class="text-xl md:text-2xl font-semibold text-neutral-900 leading-tight">
          Drop me a line.
        </p>
        <p class="text-sm text-neutral-500 max-w-sm">
          I read everything that lands in my inbox.
        </p>
        <a
          href="mailto:andres@onc9.com"
          class="mt-2 inline-flex items-center px-5 py-2.5 bg-neutral-900 text-white rounded-full text-sm font-medium hover:bg-neutral-800 transition-colors"
        >
          andres@onc9.com
        </a>
      </div>

    </div>
  </section>

  </div><!-- end scrollable content wrapper -->
  <div id="citizen-cursor" class="fixed pointer-events-none z-[100] whitespace-nowrap px-4 py-1.5 rounded-full text-[16px] font-medium text-white opacity-0 transition-opacity duration-150" aria-hidden="true"></div>
</Layout>

<!-- Citizen cursor script -->
<script>
  const cursor = document.getElementById('citizen-cursor');
  const items = document.querySelectorAll('.citizen-item');

  if (cursor) {
    items.forEach((item) => {
      item.addEventListener('mouseenter', (e) => {
        const el = e.currentTarget as HTMLElement;
        cursor.textContent = el.dataset.label || '';
        cursor.style.backgroundColor = el.dataset.color || '#000';
        cursor.style.opacity = '1';
      });

      item.addEventListener('mousemove', (e) => {
        const me = e as MouseEvent;
        const labelW = cursor.offsetWidth;
        const vw = window.innerWidth;
        // Default: open to the right of the pointer.
        // If that would overflow the right edge (e.g. German / UAE flags on
        // a narrow mobile viewport), flip the label to the left side.
        let left = me.clientX + 14;
        if (left + labelW > vw - 8) {
          left = me.clientX - 14 - labelW;
        }
        cursor.style.left = `${left}px`;
        cursor.style.top = `${me.clientY - 14}px`;
      });

      item.addEventListener('mouseleave', () => {
        cursor.style.opacity = '0';
      });
    });
  }
</script>

<!-- InitialCommit hero image carousel -->
<script>
  const cycle = document.querySelector('.ic-cycle');
  if (cycle) {
    const imgs = cycle.querySelectorAll(':scope > img, :scope > picture > img');
    let current = 0;
    setInterval(() => {
      imgs[current].classList.replace('opacity-100', 'opacity-0');
      current = (current + 1) % imgs.length;
      imgs[current].classList.replace('opacity-0', 'opacity-100');
    }, 6000);
  }
</script>

<!-- GSAP scroll animations -->
<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  gsap.to("#hero-inner", {
    scale: 0.85,
    ease: "none",
    scrollTrigger: {
      trigger: "#hero",
      start: "top top",
      end: "bottom top",
      scrub: 0.3,
    },
  });

  gsap.to("#hero-text", {
    scale: 0.8,
    ease: "none",
    scrollTrigger: {
      trigger: "#hero",
      start: "top top",
      end: "bottom top",
      scrub: 0.3,
    },
  });

  gsap.to("#hero", {
    opacity: 0,
    ease: "none",
    scrollTrigger: {
      trigger: "#hero",
      start: "bottom top",
      end: "bottom top",
      toggleActions: "play none none reverse",
    },
  });
</script>

