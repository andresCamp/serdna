<!-- Citizen cursor script -->
<script>
  const cursor = document.getElementById('citizen-cursor');
  const items = document.querySelectorAll('.citizen-item');

  if (cursor) {
    items.forEach((item) => {
      item.addEventListener('mouseenter', (e) => {
        const el = e.currentTarget as HTMLElement;
        cursor.textContent = el.dataset.label || '';
        cursor.style.backgroundColor = el.dataset.color || '#000';
        cursor.style.opacity = '1';
      });

      item.addEventListener('mousemove', (e) => {
        cursor.style.left = `${(e as MouseEvent).clientX + 14}px`;
        cursor.style.top = `${(e as MouseEvent).clientY - 14}px`;
      });

      item.addEventListener('mouseleave', () => {
        cursor.style.opacity = '0';
      });
    });
  }
</script>

<!-- InitialCommit hero image carousel -->
<script>
  const cycle = document.querySelector('.ic-cycle');
  if (cycle) {
    const imgs = cycle.querySelectorAll(':scope > img, :scope > picture > img');
    let current = 0;
    setInterval(() => {
      imgs[current].classList.replace('opacity-100', 'opacity-0');
      current = (current + 1) % imgs.length;
      imgs[current].classList.replace('opacity-0', 'opacity-100');
    }, 6000);
  }
</script>

