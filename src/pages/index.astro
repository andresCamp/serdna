  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  gsap.to("#hero-inner", {
    scale: 0.85,
    ease: "none",
    scrollTrigger: {
      trigger: "#hero",
      start: "top top",
      end: "bottom top",
      scrub: 0.3,
    },
  });

  gsap.to("#hero-text", {
    scale: 0.8,
    ease: "none",
    scrollTrigger: {
      trigger: "#hero",
      start: "top top",
      end: "bottom top",
      scrub: 0.3,
    },
  });

  gsap.to("#hero", {
    opacity: 0,
    ease: "none",
    scrollTrigger: {
      trigger: "#hero",
      start: "bottom top",
      end: "bottom top",
      toggleActions: "play none none reverse",
    },
  });
</script>

