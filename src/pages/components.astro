---
import Layout from "../layouts/Layout.astro";
import "../styles/global.css";
import DigitalRain from "../components/DigitalRain.astro";
---

<Layout title="Components — Andrés Campos">
  <section class="py-16 px-8">
    <div class="max-w-5xl mx-auto mb-8">
      <h1 class="text-3xl md:text-4xl font-bold tracking-tight text-neutral-900">
        Components
      </h1>
      <p class="mt-3 text-sm text-neutral-500 max-w-md leading-relaxed">
        Interactive experiments and visual components.
      </p>
    </div>

    <div class="max-w-5xl mx-auto">
      <div class="rounded-2xl overflow-hidden border border-neutral-200">
        <div class="px-4 py-3 border-b border-neutral-200 bg-neutral-50">
          <p class="text-xs font-medium text-neutral-500">Digital Rain</p>
        </div>
        <div class="h-[70vh] bg-white">
          <DigitalRain />
        </div>
      </div>
    </div>
  </section>
</Layout>
