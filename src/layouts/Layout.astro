---
import { ClientRouter } from "astro:transitions";
import { SlidingText } from "../components/SlidingText";

interface Props {
  title?: string;
  description?: string;
  /** Path or absolute URL of the social preview image. Defaults to /og.jpg. */
  image?: string;
  /** Open Graph object type. */
  type?: "website" | "profile" | "article";
}

const {
  title = "Andrés Campos",
  description = "Full stack product engineer. I ship AI products and features end to end, from spec to design to infrastructure.",
  image = "/og.jpg",
  type = "website",
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
const imageUrl = image.startsWith("http")
  ? image
  : new URL(image, Astro.site).toString();
---

<html lang="en">
  <head>
    <meta charset="utf-8" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content="Andrés Campos" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Andrés Campos — Full stack product engineer" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Caudex:ital,wght@0,400;0,700;1,400;1,700&family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet" />
    <ClientRouter />
  </head>
  <body class="bg-white text-neutral-900 antialiased [padding-top:env(safe-area-inset-top)] [padding-bottom:env(safe-area-inset-bottom)]">
    <!-- Nav -->
    <nav
      class="hidden md:grid sticky top-0 z-50 grid-cols-[1fr_auto_1fr] items-center px-4 sm:px-6 md:px-10 lg:px-16 py-3 md:py-4"
    >
      <a href="/" class="text-lg font-semibold tracking-tight justify-self-start">
        <SlidingText from="serdna" to="andres" client:load />
      </a>

      <div class="hidden md:flex items-center gap-1 bg-neutral-200/40 backdrop-blur-md rounded-full px-2 py-1.5 text-sm text-neutral-600">
        <a href="/#work" class="px-3.5 py-1.5 rounded-full hover:bg-white/70 hover:text-neutral-900 transition-all">Work</a>
        <a href="/projects" class="px-3.5 py-1.5 rounded-full hover:bg-white/70 hover:text-neutral-900 transition-all">Projects</a>
        <a href="/#contact" class="px-3.5 py-1.5 rounded-full hover:bg-white/70 hover:text-neutral-900 transition-all">Contact</a>
      </div>

    </nav>

    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="max-w-7xl mx-auto px-4 py-12 border-t border-neutral-200">
      <div class="flex flex-col md:flex-row justify-between items-start gap-6">
        <div>
          <p class="text-sm text-neutral-500">
            &copy; {new Date().getFullYear()} Andrés Campos
          </p>
        </div>
        <div class="flex flex-wrap gap-2 -mx-3 text-sm text-neutral-500">
          <a href="mailto:andres@onc9.com" class="inline-flex items-center min-h-11 px-3 rounded-md hover:text-neutral-900 transition-colors">Email</a>
          <a href="https://www.linkedin.com/in/andres-l-campos/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center min-h-11 px-3 rounded-md hover:text-neutral-900 transition-colors">LinkedIn</a>
          <a href="https://github.com/andresCamp" target="_blank" rel="noopener noreferrer" class="inline-flex items-center min-h-11 px-3 rounded-md hover:text-neutral-900 transition-colors">GitHub</a>
        </div>
      </div>
    </footer>
  </body>
</html>
