---
import { ClientRouter } from "astro:transitions";
import { SlidingText } from "../components/SlidingText";

interface Props {
  title?: string;
}

const { title = "Andrés Campos" } =
  Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />

    <link rel="icon" type="image/x-icon" href="/favicons/light/favicon.ico" media="(prefers-color-scheme: dark)" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicons/light/favicon-32x32.png" media="(prefers-color-scheme: dark)" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicons/light/favicon-16x16.png" media="(prefers-color-scheme: dark)" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicons/light/apple-touch-icon.png" media="(prefers-color-scheme: dark)" />
    <link rel="manifest" href="/favicons/light/site.webmanifest" media="(prefers-color-scheme: dark)" />

    <link rel="icon" type="image/x-icon" href="/favicons/dark/favicon.ico" media="(prefers-color-scheme: light)" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicons/dark/favicon-32x32.png" media="(prefers-color-scheme: light)" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicons/dark/favicon-16x16.png" media="(prefers-color-scheme: light)" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicons/dark/apple-touch-icon.png" media="(prefers-color-scheme: light)" />
    <link rel="manifest" href="/favicons/dark/site.webmanifest" media="(prefers-color-scheme: light)" />

    <link rel="icon" href="/favicon.ico" />

    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#000000" media="(prefers-color-scheme: dark)" />

    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Caudex:ital,wght@0,400;0,700;1,400;1,700&family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet" />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body class="bg-white dark:bg-black text-neutral-900 antialiased [padding-top:env(safe-area-inset-top)] [padding-bottom:env(safe-area-inset-bottom)]">
    <div class="bg-white min-h-dvh">
    <!-- Nav -->
    <nav
      class="hidden md:grid sticky top-0 z-50 grid-cols-[1fr_auto_1fr] items-center px-4 sm:px-6 md:px-10 lg:px-16 py-3 md:py-4"
    >
      <a href="/" class="text-lg font-semibold tracking-tight justify-self-start">
        <SlidingText from="serdna" to="andres" client:load />
      </a>

      <div class="hidden md:flex items-center gap-1 bg-neutral-200/40 backdrop-blur-md rounded-full px-2 py-1.5 text-sm text-neutral-600">
        <a href="/#work" class="px-3.5 py-1.5 rounded-full hover:bg-white/70 hover:text-neutral-900 transition-all">Work</a>
        <a href="/projects" class="px-3.5 py-1.5 rounded-full hover:bg-white/70 hover:text-neutral-900 transition-all">Projects</a>
        <a href="/#contact" class="px-3.5 py-1.5 rounded-full hover:bg-white/70 hover:text-neutral-900 transition-all">Contact</a>
      </div>

    </nav>

    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="max-w-7xl mx-auto px-4 py-12 border-t border-neutral-200">
      <div class="flex flex-col md:flex-row justify-between items-start gap-6">
        <div>
          <p class="text-sm text-neutral-500">
            &copy; {new Date().getFullYear()} Andrés Campos
          </p>
        </div>
        <div class="flex flex-wrap gap-2 -mx-3 text-sm text-neutral-500">
          <a href="mailto:andres@onc9.com" class="inline-flex items-center min-h-11 px-3 rounded-md hover:text-neutral-900 transition-colors">Email</a>
          <a href="https://www.linkedin.com/in/andres-l-campos/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center min-h-11 px-3 rounded-md hover:text-neutral-900 transition-colors">LinkedIn</a>
          <a href="https://github.com/andresCamp" target="_blank" rel="noopener noreferrer" class="inline-flex items-center min-h-11 px-3 rounded-md hover:text-neutral-900 transition-colors">GitHub</a>
        </div>
      </div>
    </footer>
    </div>
  </body>
</html>
